# ─── Claude (Anthropic) ───────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ─── X (Twitter) API ─────────────────────────────────────────────────────────
# All 4 required. Get from developer.twitter.com → Free tier is sufficient.
X_API_KEY=your_x_api_key_here
X_API_SECRET=your_x_api_secret_here
X_ACCESS_TOKEN=your_x_access_token_here
X_ACCESS_TOKEN_SECRET=your_x_access_token_secret_here

# ─── Telegram ─────────────────────────────────────────────────────────────────
# Create bot: message @BotFather on Telegram → /newbot
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
# Get your chat ID: message @userinfobot on Telegram
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# ─── Tavily (web search for Market Commentary posts) ─────────────────────────
# Free tier at https://tavily.com
TAVILY_API_KEY=your_tavily_api_key_here

# ─── Scheduling (optional — change posting window) ───────────────────────────
# Default window: 23:00–01:00 UTC = 6–8pm US Eastern = 9–11am Sydney/Melbourne
SCHEDULE_START_UTC=23
SCHEDULE_WINDOW_MINS=120

# ─── Approval timeout ─────────────────────────────────────────────────────────
# Seconds to wait for Telegram approval before auto-posting (default: 7200 = 2h)
APPROVAL_TIMEOUT_SECS=7200
